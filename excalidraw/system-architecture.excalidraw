    {"id":"topic3_t","type":"text","x":690,"y":538,"width":240,"height":125,"text":"Topic: task-history\n───────────────────────────\nPartitions: 32\nReplication: 3\nRetention: 1 day (consumed)\n\nKey: task_id (UUID)\nValue: JSON {task_id,\n  status, at (RFC3339Nano)}\n\nConsumed by:\n  history.KafkaConsumer\n  → batch CopyFrom → PG","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":37,"version":1,"versionNonce":37,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"topic3","originalText":"Topic: task-history\n───────────────────────────\nPartitions: 32\nReplication: 3\nRetention: 1 day (consumed)\n\nKey: task_id (UUID)\nValue: JSON {task_id,\n  status, at (RFC3339Nano)}\n\nConsumed by:\n  history.KafkaConsumer\n  → batch CopyFrom → PG","lineHeight":1.25,"baseline":120},

