    {"id":"hc_t","type":"text","x":735,"y":923,"width":200,"height":95,"text":"history.KafkaConsumer\n────────────────────────\nGroup: \"history-writers\"\nTopic: task-history\n\nBatch accumulate:\n  1000 events or 100ms\npgx.CopyFrom(\n  task_history,\n  [task_id, status, at])","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":55,"version":1,"versionNonce":55,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"hist_consumer","originalText":"history.KafkaConsumer\n────────────────────────\nGroup: \"history-writers\"\nTopic: task-history\n\nBatch accumulate:\n  1000 events or 100ms\npgx.CopyFrom(\n  task_history,\n  [task_id, status, at])","lineHeight":1.25,"baseline":90},

