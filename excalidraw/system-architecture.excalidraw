    {"id":"observ_t","type":"text","x":1030,"y":208,"width":200,"height":325,"text":"Observability Stack\n────────────────────\n\nOpenTelemetry\n  OTLP HTTP exporter\n  Trace context in\n  Kafka headers\n  Sampled 1/1000\n\nPrometheus\n  /metrics on all pods\n  kafka_produce_total\n  kafka_consume_total\n  kafka_consume_lag\n  task_end_to_end_\n    latency_seconds\n  history_buffer_depth\n  history_flush_total\n  pg_pool_active_conns\n\nGrafana\n  Dashboards for\n  throughput, lag,\n  latency percentiles\n\nJaeger / Tempo\n  Distributed traces","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":81,"version":1,"versionNonce":81,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"observ_outer","originalText":"Observability Stack\n────────────────────\n\nOpenTelemetry\n  OTLP HTTP exporter\n  Trace context in\n  Kafka headers\n  Sampled 1/1000\n\nPrometheus\n  /metrics on all pods\n  kafka_produce_total\n  kafka_consume_total\n  kafka_consume_lag\n  task_end_to_end_\n    latency_seconds\n  history_buffer_depth\n  history_flush_total\n  pg_pool_active_conns\n\nGrafana\n  Dashboards for\n  throughput, lag,\n  latency percentiles\n\nJaeger / Tempo\n  Distributed traces","lineHeight":1.25,"baseline":320},

