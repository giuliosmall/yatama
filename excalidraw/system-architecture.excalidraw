    {"id":"api_handler_t","type":"text","x":330,"y":248,"width":180,"height":145,"text":"internal/api/handler.go\n─────────────────────\nHandler struct {\n  repo     Repository\n  registry *Registry\n  producer queue.Producer\n  drain    *DrainState\n}\n\nslogMiddleware\nmetricsMiddleware\nPrometheus:\n  tasks_created_total\n  http_requests_total","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":25,"version":1,"versionNonce":25,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"api_handler","originalText":"internal/api/handler.go\n─────────────────────\nHandler struct {\n  repo     Repository\n  registry *Registry\n  producer queue.Producer\n  drain    *DrainState\n}\n\nslogMiddleware\nmetricsMiddleware\nPrometheus:\n  tasks_created_total\n  http_requests_total","lineHeight":1.25,"baseline":140},

