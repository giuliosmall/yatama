    {"id":"api_http_t","type":"text","x":130,"y":248,"width":160,"height":145,"text":"chi Router :8080\n─────────────────\nPOST /tasks\nGET  /tasks/{id}\nGET  /tasks/{id}/history\nGET  /health\nGET  /ready\nGET  /metrics\nGET  /dlq/tasks\nPOST /dlq/tasks/{id}/retry","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":23,"version":1,"versionNonce":23,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"api_http","originalText":"chi Router :8080\n─────────────────\nPOST /tasks\nGET  /tasks/{id}\nGET  /tasks/{id}/history\nGET  /health\nGET  /ready\nGET  /metrics\nGET  /dlq/tasks\nPOST /dlq/tasks/{id}/retry","lineHeight":1.25,"baseline":140},

