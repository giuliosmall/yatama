    {"id":"pg_t","type":"text","x":260,"y":1288,"width":540,"height":145,"text":"PostgreSQL (metadata store, NOT the queue)\n──────────────────────────────────────────────────────────────────────────────\ntasks        │ id, name, type, payload(JSONB), status, priority,\n             │ retry_count, max_retries, timeout_seconds, idempotency_key,\n             │ created_at, updated_at, run_after\n             │ idx: idx_tasks_claim (priority DESC, created_at) WHERE status='queued'\n             │ idx: idx_tasks_terminal_status (id) WHERE status IN ('succeeded','failed','dead_lettered')\n─────────────┼─────────────────────────────────────────────────────────────\ntask_history │ PARTITIONED BY RANGE (occurred_at)  ← monthly partitions\n  (monthly)  │ id, task_id, status, occurred_at\n             │ idx: idx_task_history_task_id (task_id, occurred_at ASC)\n─────────────┼─────────────────────────────────────────────────────────────\ndead_letter  │ id, original_task_id, name, type, payload, error_message,\n  _queue     │ dead_lettered_at, original_created_at","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":71,"version":1,"versionNonce":71,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"pg_box","originalText":"PostgreSQL (metadata store, NOT the queue)\n──────────────────────────────────────────────────────────────────────────────\ntasks        │ id, name, type, payload(JSONB), status, priority,\n             │ retry_count, max_retries, timeout_seconds, idempotency_key,\n             │ created_at, updated_at, run_after\n             │ idx: idx_tasks_claim (priority DESC, created_at) WHERE status='queued'\n             │ idx: idx_tasks_terminal_status (id) WHERE status IN ('succeeded','failed','dead_lettered')\n─────────────┼─────────────────────────────────────────────────────────────\ntask_history │ PARTITIONED BY RANGE (occurred_at)  ← monthly partitions\n  (monthly)  │ id, task_id, status, occurred_at\n             │ idx: idx_task_history_task_id (task_id, occurred_at ASC)\n─────────────┼─────────────────────────────────────────────────────────────\ndead_letter  │ id, original_task_id, name, type, payload, error_message,\n  _queue     │ dead_lettered_at, original_created_at","lineHeight":1.25,"baseline":140},

