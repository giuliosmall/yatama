    {"id":"api_producer_t","type":"text","x":550,"y":248,"width":160,"height":145,"text":"queue.Producer\n(internal/queue/kafka.go)\n─────────────────────\nKafkaProducer {\n  client: franz-go\n  topic: \"tasks\"\n  dlqTopic: \"tasks-dlq\"\n}\n\nBatch: 1MB / 5ms linger\nAcks: AllISRAcks\nPartition: StickyKey\nBuffer: 100K records","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":27,"version":1,"versionNonce":27,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"api_producer","originalText":"queue.Producer\n(internal/queue/kafka.go)\n─────────────────────\nKafkaProducer {\n  client: franz-go\n  topic: \"tasks\"\n  dlqTopic: \"tasks-dlq\"\n}\n\nBatch: 1MB / 5ms linger\nAcks: AllISRAcks\nPartition: StickyKey\nBuffer: 100K records","lineHeight":1.25,"baseline":140},

