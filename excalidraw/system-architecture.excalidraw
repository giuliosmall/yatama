    {"id":"reg_t","type":"text","x":1030,"y":608,"width":200,"height":115,"text":"task.Registry\n(internal/task/registry.go)\n────────────────────\nsync.RWMutex map\n\nRegistered TaskFuncs:\n  send_email\n    → pkg/email.SendEmail\n  run_query\n    → pkg/query.RunQuery\n\nTaskFunc = func(ctx,\n  map[string]string) error","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":91,"version":1,"versionNonce":91,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"registry_box","originalText":"task.Registry\n(internal/task/registry.go)\n────────────────────\nsync.RWMutex map\n\nRegistered TaskFuncs:\n  send_email\n    → pkg/email.SendEmail\n  run_query\n    → pkg/query.RunQuery\n\nTaskFunc = func(ctx,\n  map[string]string) error","lineHeight":1.25,"baseline":110},

