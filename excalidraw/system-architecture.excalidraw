    {"id":"pgb_t","type":"text","x":260,"y":1118,"width":260,"height":85,"text":"PgBouncer :6432\n────────────────────────────────\npool_mode = transaction\ndefault_pool_size = 100\nmax_client_conn = 2000\nreserve_pool_size = 25\n→ postgres-postgresql:5432","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":61,"version":1,"versionNonce":61,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"pgbouncer_box","originalText":"PgBouncer :6432\n────────────────────────────────\npool_mode = transaction\ndefault_pool_size = 100\nmax_client_conn = 2000\nreserve_pool_size = 25\n→ postgres-postgresql:5432","lineHeight":1.25,"baseline":80},

