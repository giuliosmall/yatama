    {"id":"api_repo_t","type":"text","x":750,"y":248,"width":180,"height":145,"text":"task.Repository\n(PostgresRepository)\n─────────────────────\nCreateTask(req)\n  → INSERT tasks\n  → INSERT task_history\n  → RETURNING *\n\nGetTask(id)\nGetTaskHistory(taskID)\nListDLQTasks()\nRetryDLQTask(dlqID)\n\npgxpool → PgBouncer","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":29,"version":1,"versionNonce":29,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"api_repo","originalText":"task.Repository\n(PostgresRepository)\n─────────────────────\nCreateTask(req)\n  → INSERT tasks\n  → INSERT task_history\n  → RETURNING *\n\nGetTask(id)\nGetTaskHistory(taskID)\nListDLQTasks()\nRetryDLQTask(dlqID)\n\npgxpool → PgBouncer","lineHeight":1.25,"baseline":140},

