    {"id":"consumer_t","type":"text","x":130,"y":808,"width":180,"height":205,"text":"queue.Consumer\n(KafkaConsumer)\n──────────────────\nConsumerGroup:\n  \"task-workers\"\n\nFetchMaxBytes: 50MB\nSessionTimeout: 30s\nDisableAutoCommit\nBlockRebalanceOnPoll\nCooperativeRebalance\n\nConsume(ctx) →\n  <-chan Delivery {\n    Message\n    Ack()  → commit\n    Nack() → redeliver\n  }","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":43,"version":1,"versionNonce":43,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"consumer_box","originalText":"queue.Consumer\n(KafkaConsumer)\n──────────────────\nConsumerGroup:\n  \"task-workers\"\n\nFetchMaxBytes: 50MB\nSessionTimeout: 30s\nDisableAutoCommit\nBlockRebalanceOnPoll\nCooperativeRebalance\n\nConsume(ctx) →\n  <-chan Delivery {\n    Message\n    Ack()  → commit\n    Nack() → redeliver\n  }","lineHeight":1.25,"baseline":200},

    {"id":"pool_box","type":"rectangle","x":340,"y":800,"width":200,"height":220,"strokeColor":"#5c7cfa","backgroundColor":"#bac8ff","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":44,"version":1,"versionNonce":44,"isDeleted":false,"boundElements":[{"type":"text","id":"pool_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"pool_t","type":"text","x":350,"y":808,"width":180,"height":205,"text":"worker.Pool\n(internal/worker/pool.go)\n──────────────────\n64 goroutines/pod\n\nfor d := range deliveries:\n  registry.Get(d.Type)\n  ctx = WithTimeout(d.Timeout)\n  fn(ctx, d.Payload)\n  if err == nil:\n    UpdateTaskStatus(\"ok\")\n    d.Ack()\n  else if retries left:\n    RequeueTask(id)\n    d.Ack()\n  else:\n    MoveTaskToDLQ(id, err)\n    d.Ack()","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":45,"version":1,"versionNonce":45,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"pool_box","originalText":"worker.Pool\n(internal/worker/pool.go)\n──────────────────\n64 goroutines/pod\n\nfor d := range deliveries:\n  registry.Get(d.Type)\n  ctx = WithTimeout(d.Timeout)\n  fn(ctx, d.Payload)\n  if err == nil:\n    UpdateTaskStatus(\"ok\")\n    d.Ack()\n  else if retries left:\n    RequeueTask(id)\n    d.Ack()\n  else:\n    MoveTaskToDLQ(id, err)\n    d.Ack()","lineHeight":1.25,"baseline":200},

