    {"id":"topic2_t","type":"text","x":410,"y":538,"width":230,"height":125,"text":"Topic: tasks-dlq\n─────────────────────────\nPartitions: 16\nReplication: 3\nRetention: 30 days\n\nKey: task.Type\nValue: same as tasks\nHeaders:\n  task_id: UUID\n  error: \"reason string\"\n\nConsumed by: API retry endpoint","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":35,"version":1,"versionNonce":35,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"topic2","originalText":"Topic: tasks-dlq\n─────────────────────────\nPartitions: 16\nReplication: 3\nRetention: 30 days\n\nKey: task.Type\nValue: same as tasks\nHeaders:\n  task_id: UUID\n  error: \"reason string\"\n\nConsumed by: API retry endpoint","lineHeight":1.25,"baseline":120},

