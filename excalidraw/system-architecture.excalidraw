    {"id":"topic1_t","type":"text","x":130,"y":538,"width":230,"height":125,"text":"Topic: tasks\n─────────────────────────\nPartitions: 128\nReplication: 3\nRetention: 7 days\nMax message: 1MB\n\nKey: task.Type (string)\nValue: JSON {task_id, name,\n  type, payload, priority,\n  max_retries, timeout,\n  retry_count}","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":33,"version":1,"versionNonce":33,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"topic1","originalText":"Topic: tasks\n─────────────────────────\nPartitions: 128\nReplication: 3\nRetention: 7 days\nMax message: 1MB\n\nKey: task.Type (string)\nValue: JSON {task_id, name,\n  type, payload, priority,\n  max_retries, timeout,\n  retry_count}","lineHeight":1.25,"baseline":120},

