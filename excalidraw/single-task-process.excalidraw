    {"id":"s2t","type":"text","x":60,"y":168,"width":380,"height":85,"text":"2. handler.CreateTask()  (internal/api/handler.go:125)\n   json.Decode(body) → CreateTaskRequest\n   ✓ req.Name != \"\"       → 400 NAME_REQUIRED\n   ✓ req.Type != \"\"       → 400 TYPE_REQUIRED\n   ✓ registry.Get(type)   → 400 UNKNOWN_TASK_TYPE\n   ✓ req.Payload != nil   → 400 PAYLOAD_NULL","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":21,"version":1,"versionNonce":21,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s2","originalText":"2. handler.CreateTask()  (internal/api/handler.go:125)\n   json.Decode(body) → CreateTaskRequest\n   ✓ req.Name != \"\"       → 400 NAME_REQUIRED\n   ✓ req.Type != \"\"       → 400 TYPE_REQUIRED\n   ✓ registry.Get(type)   → 400 UNKNOWN_TASK_TYPE\n   ✓ req.Payload != nil   → 400 PAYLOAD_NULL","lineHeight":1.25,"baseline":80},

    {"id":"s3","type":"rectangle","x":50,"y":280,"width":400,"height":120,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":30,"version":1,"versionNonce":30,"isDeleted":false,"boundElements":[{"type":"text","id":"s3t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s3t","type":"text","x":60,"y":288,"width":380,"height":105,"text":"3. repo.CreateTask(ctx, req)  (repository.go:133)\n   BEGIN tx\n   INSERT INTO tasks (name, type, payload, priority,\n     max_retries, timeout_seconds, idempotency_key)\n     RETURNING id, name, type, ..., run_after\n   INSERT INTO task_history (task_id, status='queued')\n   COMMIT\n   → returns *Task{ID: uuid, Status: \"queued\", ...}\n   Idempotency: ON CONFLICT → 200 + existing ID","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":31,"version":1,"versionNonce":31,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s3","originalText":"3. repo.CreateTask(ctx, req)  (repository.go:133)\n   BEGIN tx\n   INSERT INTO tasks (name, type, payload, priority,\n     max_retries, timeout_seconds, idempotency_key)\n     RETURNING id, name, type, ..., run_after\n   INSERT INTO task_history (task_id, status='queued')\n   COMMIT\n   → returns *Task{ID: uuid, Status: \"queued\", ...}\n   Idempotency: ON CONFLICT → 200 + existing ID","lineHeight":1.25,"baseline":100},

    {"id":"s4","type":"rectangle","x":50,"y":420,"width":400,"height":100,"strokeColor":"#e8590c","backgroundColor":"#fff4e6","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":40,"version":1,"versionNonce":40,"isDeleted":false,"boundElements":[{"type":"text","id":"s4t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s4t","type":"text","x":60,"y":428,"width":380,"height":85,"text":"4. producer.Enqueue(ctx, Message{...})  (kafka.go:67)\n   Record {\n     Topic: \"tasks\",  Key: []byte(task.Type)\n     Value: JSON(message)\n     Headers: [task_id=uuid, retry_count=0]\n   }\n   client.ProduceSync(ctx, record)\n   → partition assigned by StickyKeyPartitioner","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":41,"version":1,"versionNonce":41,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s4","originalText":"4. producer.Enqueue(ctx, Message{...})  (kafka.go:67)\n   Record {\n     Topic: \"tasks\",  Key: []byte(task.Type)\n     Value: JSON(message)\n     Headers: [task_id=uuid, retry_count=0]\n   }\n   client.ProduceSync(ctx, record)\n   → partition assigned by StickyKeyPartitioner","lineHeight":1.25,"baseline":80},

