    {"id":"phase_dispatch","type":"text","x":50,"y":625,"width":300,"height":20,"text":"DISPATCH (Kafka → Worker Pod)","fontSize":14,"fontFamily":1,"textAlign":"left","strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":61,"version":1,"versionNonce":61,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":null,"originalText":"DISPATCH (Kafka → Worker Pod)","lineHeight":1.25,"baseline":14,"verticalAlign":"top"},

    {"id":"s6","type":"rectangle","x":50,"y":655,"width":400,"height":100,"strokeColor":"#e8590c","backgroundColor":"#fff4e6","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":70,"version":1,"versionNonce":70,"isDeleted":false,"boundElements":[{"type":"text","id":"s6t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s6t","type":"text","x":60,"y":663,"width":380,"height":85,"text":"6. KafkaConsumer.Consume()  (kafka.go:148)\n   client.PollFetches(ctx)\n   fetches.EachRecord(func(r *kgo.Record) {\n     msg = serializer.Unmarshal(r.Value)\n     msg.Meta = {partition, offset, topic}\n     ch <- Delivery{Message: msg, Ack: ..., Nack: ...}\n   })\n   client.AllowRebalance()  // cooperative","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":71,"version":1,"versionNonce":71,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s6","originalText":"6. KafkaConsumer.Consume()  (kafka.go:148)\n   client.PollFetches(ctx)\n   fetches.EachRecord(func(r *kgo.Record) {\n     msg = serializer.Unmarshal(r.Value)\n     msg.Meta = {partition, offset, topic}\n     ch <- Delivery{Message: msg, Ack: ..., Nack: ...}\n   })\n   client.AllowRebalance()  // cooperative","lineHeight":1.25,"baseline":80},

    {"id":"s7","type":"rectangle","x":50,"y":775,"width":400,"height":60,"strokeColor":"#5c7cfa","backgroundColor":"#edf2ff","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":80,"version":1,"versionNonce":80,"isDeleted":false,"boundElements":[{"type":"text","id":"s7t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s7t","type":"text","x":60,"y":783,"width":380,"height":45,"text":"7. pool.run() receives on <-chan Delivery  (pool.go)\n   select { case d := <-deliveries: ... }\n   → converts Delivery.Message to *task.Task struct","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":81,"version":1,"versionNonce":81,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s7","originalText":"7. pool.run() receives on <-chan Delivery  (pool.go)\n   select { case d := <-deliveries: ... }\n   → converts Delivery.Message to *task.Task struct","lineHeight":1.25,"baseline":40},

    {"id":"divider2","type":"line","x":30,"y":865,"width":960,"height":0,"strokeColor":"#ced4da","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":82,"version":1,"versionNonce":82,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"points":[[0,0],[960,0]],"lastCommittedPoint":null,"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null},

    {"id":"phase_exec","type":"text","x":50,"y":880,"width":300,"height":20,"text":"EXECUTION (Worker Goroutine)","fontSize":14,"fontFamily":1,"textAlign":"left","strokeColor":"#5c7cfa","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":83,"version":1,"versionNonce":83,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":null,"originalText":"EXECUTION (Worker Goroutine)","lineHeight":1.25,"baseline":14,"verticalAlign":"top"},

    {"id":"s8","type":"rectangle","x":50,"y":910,"width":400,"height":120,"strokeColor":"#5c7cfa","backgroundColor":"#edf2ff","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":90,"version":1,"versionNonce":90,"isDeleted":false,"boundElements":[{"type":"text","id":"s8t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s8t","type":"text","x":60,"y":918,"width":380,"height":105,"text":"8. pool.execute(ctx, task, workerID)  (pool.go:244)\n   fn, ok := registry.Get(task.Type)\n   if !ok → repo.UpdateTaskStatus(id, \"failed\"); return\n\n   timeout := task.TimeoutSeconds * time.Second\n   taskCtx, cancel := context.WithTimeout(ctx, timeout)\n   defer cancel()\n\n   tasksInProgress.Inc()\n   start := time.Now()","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":91,"version":1,"versionNonce":91,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s8","originalText":"8. pool.execute(ctx, task, workerID)  (pool.go:244)\n   fn, ok := registry.Get(task.Type)\n   if !ok → repo.UpdateTaskStatus(id, \"failed\"); return\n\n   timeout := task.TimeoutSeconds * time.Second\n   taskCtx, cancel := context.WithTimeout(ctx, timeout)\n   defer cancel()\n\n   tasksInProgress.Inc()\n   start := time.Now()","lineHeight":1.25,"baseline":100},

    {"id":"s9","type":"rectangle","x":50,"y":1050,"width":400,"height":70,"strokeColor":"#5c7cfa","backgroundColor":"#bac8ff","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":100,"version":1,"versionNonce":100,"isDeleted":false,"boundElements":[{"type":"text","id":"s9t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"s9t","type":"text","x":60,"y":1058,"width":380,"height":55,"text":"9. err := fn(taskCtx, task.Payload)\n   e.g. email.SendEmail(ctx, {\"to\":\"a@b.com\",\"subject\":\"Hi\"})\n   e.g. query.RunQuery(ctx, {\"query\":\"SELECT 1\"})\n   duration := time.Since(start); tasksInProgress.Dec()","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":101,"version":1,"versionNonce":101,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s9","originalText":"9. err := fn(taskCtx, task.Payload)\n   e.g. email.SendEmail(ctx, {\"to\":\"a@b.com\",\"subject\":\"Hi\"})\n   e.g. query.RunQuery(ctx, {\"query\":\"SELECT 1\"})\n   duration := time.Since(start); tasksInProgress.Dec()","lineHeight":1.25,"baseline":50},

