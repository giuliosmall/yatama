    {"id":"s1t","type":"text","x":60,"y":92,"width":380,"height":40,"text":"1. HTTP Request\nPOST /tasks {name, type, payload, priority, max_retries, timeout_seconds}","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":11,"version":1,"versionNonce":11,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"s1","originalText":"1. HTTP Request\nPOST /tasks {name, type, payload, priority, max_retries, timeout_seconds}","lineHeight":1.25,"baseline":35},

