    {"id":"success_box","type":"rectangle","x":500,"y":1100,"width":480,"height":150,"strokeColor":"#2f9e44","backgroundColor":"#ebfbee","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":120,"version":1,"versionNonce":120,"isDeleted":false,"boundElements":[{"type":"text","id":"succ_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"succ_t","type":"text","x":510,"y":1108,"width":460,"height":135,"text":"10a. SUCCESS  (pool.handleSuccess)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"succeeded\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"succeeded\").Inc()\n\nrepo.UpdateTaskStatus(ctx, id, \"succeeded\")\n  → BEGIN; UPDATE tasks SET status='succeeded', updated_at=now();\n    INSERT INTO task_history (task_id, 'succeeded'); COMMIT\n\nhistoryWriter.Write(Event{TaskID, \"succeeded\", time.Now()})\n\ndelivery.Ack()  → client.MarkCommitRecords(record)\n                → offset committed on next CommitMarkedOffsets()","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":121,"version":1,"versionNonce":121,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"success_box","originalText":"10a. SUCCESS  (pool.handleSuccess)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"succeeded\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"succeeded\").Inc()\n\nrepo.UpdateTaskStatus(ctx, id, \"succeeded\")\n  → BEGIN; UPDATE tasks SET status='succeeded', updated_at=now();\n    INSERT INTO task_history (task_id, 'succeeded'); COMMIT\n\nhistoryWriter.Write(Event{TaskID, \"succeeded\", time.Now()})\n\ndelivery.Ack()  → client.MarkCommitRecords(record)\n                → offset committed on next CommitMarkedOffsets()","lineHeight":1.25,"baseline":130},

    {"id":"fail_decision","type":"diamond","x":570,"y":1310,"width":240,"height":90,"strokeColor":"#e03131","backgroundColor":"#fff5f5","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":130,"version":1,"versionNonce":130,"isDeleted":false,"boundElements":[{"type":"text","id":"fd_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":2}},
    {"id":"fd_t","type":"text","x":620,"y":1338,"width":140,"height":35,"text":"retryCount\n< maxRetries?","fontSize":14,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","strokeColor":"#e03131","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":131,"version":1,"versionNonce":131,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"fail_decision","originalText":"retryCount\n< maxRetries?","lineHeight":1.25,"baseline":30},

    {"id":"retry_box","type":"rectangle","x":500,"y":1440,"width":480,"height":145,"strokeColor":"#e67700","backgroundColor":"#fff4e6","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":140,"version":1,"versionNonce":140,"isDeleted":false,"boundElements":[{"type":"text","id":"retry_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"retry_t","type":"text","x":510,"y":1448,"width":460,"height":130,"text":"10b. RETRY  (pool.handleFailure, retries remaining)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"retry\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"retry\").Inc()\n\nrepo.RequeueTask(ctx, id)\n  → BEGIN; UPDATE tasks SET status='queued',\n    retry_count=retry_count+1, updated_at=now(),\n    run_after=now() + LEAST(5*2^retry_count, 5min);\n    INSERT INTO task_history (task_id, 'queued'); COMMIT\n\ndelivery.Ack()  → original message done\n↺ task re-enters queue → will be claimed again after run_after","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":141,"version":1,"versionNonce":141,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"retry_box","originalText":"10b. RETRY  (pool.handleFailure, retries remaining)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"retry\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"retry\").Inc()\n\nrepo.RequeueTask(ctx, id)\n  → BEGIN; UPDATE tasks SET status='queued',\n    retry_count=retry_count+1, updated_at=now(),\n    run_after=now() + LEAST(5*2^retry_count, 5min);\n    INSERT INTO task_history (task_id, 'queued'); COMMIT\n\ndelivery.Ack()  → original message done\n↺ task re-enters queue → will be claimed again after run_after","lineHeight":1.25,"baseline":125},

    {"id":"dlq_box","type":"rectangle","x":500,"y":1610,"width":480,"height":145,"strokeColor":"#c92a2a","backgroundColor":"#ffe3e3","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":150,"version":1,"versionNonce":150,"isDeleted":false,"boundElements":[{"type":"text","id":"dlq_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"dlq_t","type":"text","x":510,"y":1618,"width":460,"height":130,"text":"10c. DEAD LETTER  (pool.handleFailure, retries exhausted)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"dead_lettered\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"dead_lettered\").Inc()\ndlqTasksDepth.Inc()\n\nrepo.MoveTaskToDLQ(ctx, id, err.Error())\n  → BEGIN;\n    INSERT INTO dead_letter_queue SELECT ... FROM tasks WHERE id=$1;\n    UPDATE tasks SET status='dead_lettered';\n    INSERT INTO task_history (task_id, 'dead_lettered');\n    COMMIT\n\ndelivery.Ack()  → TERMINAL STATE (recoverable via POST /dlq/tasks/{id}/retry)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":151,"version":1,"versionNonce":151,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"dlq_box","originalText":"10c. DEAD LETTER  (pool.handleFailure, retries exhausted)\n─────────────────────────────────────────────────────\ntaskDurationSeconds.WithLabelValues(type, \"dead_lettered\").Observe(dur)\ntasksProcessedTotal.WithLabelValues(type, \"dead_lettered\").Inc()\ndlqTasksDepth.Inc()\n\nrepo.MoveTaskToDLQ(ctx, id, err.Error())\n  → BEGIN;\n    INSERT INTO dead_letter_queue SELECT ... FROM tasks WHERE id=$1;\n    UPDATE tasks SET status='dead_lettered';\n    INSERT INTO task_history (task_id, 'dead_lettered');\n    COMMIT\n\ndelivery.Ack()  → TERMINAL STATE (recoverable via POST /dlq/tasks/{id}/retry)","lineHeight":1.25,"baseline":125},

    {"id":"status_flow","type":"rectangle","x":50,"y":1300,"width":400,"height":200,"strokeColor":"#868e96","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":160,"version":1,"versionNonce":160,"isDeleted":false,"boundElements":[{"type":"text","id":"sf_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"sf_t","type":"text","x":60,"y":1308,"width":380,"height":185,"text":"Status State Machine\n──────────────────────────────────\n\n  ┌──────────┐    ClaimTask     ┌─────────┐\n  │  queued  │ ───────────────→ │ running │\n  └──────────┘                  └────┬────┘\n       ↑                             │\n       │ RequeueTask         ┌───────┴────────┐\n       │ (retries left)      │                │\n       │               ┌─────┴────┐  ┌────────┴───────┐\n       └───────────────│ succeeded│  │ dead_lettered  │\n                       └──────────┘  └────────────────┘\n                                     (POST /dlq/.../retry\n                                      resets to queued)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":161,"version":1,"versionNonce":161,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"status_flow","originalText":"Status State Machine\n──────────────────────────────────\n\n  ┌──────────┐    ClaimTask     ┌─────────┐\n  │  queued  │ ───────────────→ │ running │\n  └──────────┘                  └────┬────┘\n       ↑                             │\n       │ RequeueTask         ┌───────┴────────┐\n       │ (retries left)      │                │\n       │               ┌─────┴────┐  ┌────────┴───────┐\n       └───────────────│ succeeded│  │ dead_lettered  │\n                       └──────────┘  └────────────────┘\n                                     (POST /dlq/.../retry\n                                      resets to queued)","lineHeight":1.25,"baseline":180},

    {"id":"backoff_box","type":"rectangle","x":50,"y":1530,"width":400,"height":100,"strokeColor":"#868e96","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":170,"version":1,"versionNonce":170,"isDeleted":false,"boundElements":[{"type":"text","id":"bb_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"bb_t","type":"text","x":60,"y":1538,"width":380,"height":85,"text":"Exponential Backoff\n──────────────────────────────────\nrun_after = now() + LEAST(5 × 2^retry_count, 5 min)\n\nRetry 0: immediate    Retry 3: +40s\nRetry 1: +10s         Retry 4: +80s\nRetry 2: +20s         Retry 5+: +5min (capped)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":171,"version":1,"versionNonce":171,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"backoff_box","originalText":"Exponential Backoff\n──────────────────────────────────\nrun_after = now() + LEAST(5 × 2^retry_count, 5 min)\n\nRetry 0: immediate    Retry 3: +40s\nRetry 1: +10s         Retry 4: +80s\nRetry 2: +20s         Retry 5+: +5min (capped)","lineHeight":1.25,"baseline":80},

    {"id":"reaper_box","type":"rectangle","x":50,"y":1660,"width":400,"height":95,"strokeColor":"#868e96","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":180,"version":1,"versionNonce":180,"isDeleted":false,"boundElements":[{"type":"text","id":"rp_t"}],"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":{"type":3}},
    {"id":"rp_t","type":"text","x":60,"y":1668,"width":380,"height":80,"text":"Reaper (every 30s)\n──────────────────────────────────\nSELECT id FROM tasks\n  WHERE status='running'\n  AND updated_at + make_interval(secs=>timeout_seconds) < now()\n\nFor each stuck task:\n  retries left → reapRequeue (run_after=now())\n  exhausted    → MoveTaskToDLQ(\"reaped: stuck\")","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":181,"version":1,"versionNonce":181,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"groupIds":[],"frameId":null,"roundness":null,"containerId":"reaper_box","originalText":"Reaper (every 30s)\n──────────────────────────────────\nSELECT id FROM tasks\n  WHERE status='running'\n  AND updated_at + make_interval(secs=>timeout_seconds) < now()\n\nFor each stuck task:\n  retries left → reapRequeue (run_after=now())\n  exhausted    → MoveTaskToDLQ(\"reaped: stuck\")","lineHeight":1.25,"baseline":75},

